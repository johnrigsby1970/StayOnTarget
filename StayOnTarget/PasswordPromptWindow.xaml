<Window x:Class="StayOnTarget.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StayOnTarget - Security" Height="300" Width="420" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F9F9F9" Foreground="#2C3E50">
    
    <Window.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EAEAEA"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DDDDDD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#D32F2F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="PROTECTED STORAGE" FontSize="10" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,4"/>
            <TextBlock x:Name="InstructionText" Text="Enter your master password to unlock your data." 
                       TextWrapping="Wrap" FontSize="13" Foreground="#555555" Margin="0,0,0,6"/>
    
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Path Data="M6,10V7A4,4,0,0,1,14,7V10M8,10H12M5,10H15A2,2,0,0,1,17,12V19A2,2,0,0,1,15,21H5A2,2,0,0,1,3,19V12A2,2,0,0,1,5,10Z" 
                      Stroke="#666666" StrokeThickness="1" Width="20" Height="25" 
                      Stretch="Uniform"
                      Margin="0,1,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="AES-256 local hardware encryption active" FontSize="11" FontStyle="Italic" Foreground="#666666" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="Master Password" FontSize="11" Foreground="#666666" Margin="0,0,0,6" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordInput" KeyDown="PasswordInput_KeyDown" />
            
            <TextBlock x:Name="ConfirmPasswordLabel" Text="Confirm Master Password" FontSize="11" Foreground="#666666" Margin="0,12,0,6" Visibility="Collapsed" FontWeight="SemiBold"/>
            <PasswordBox x:Name="ConfirmPasswordInput" Visibility="Collapsed" KeyDown="PasswordInput_KeyDown"/>
            
            <CheckBox x:Name="UseWindowsHelloCheckBox" 
                      Content="Use Windows Hello to unlock this app in the future" 
                      IsChecked="True" 
                      FontSize="12" 
                      Foreground="#555555" 
                      Margin="0,15,0,0"
                      Cursor="Hand"/>
        </StackPanel>

        <Border x:Name="ErrorMessageBorder" Grid.Row="2" Background="#FFEBEE" BorderBrush="#FFCDD2" BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="12,8" Visibility="Collapsed">
            <TextBlock x:Name="ErrorMessage" Foreground="#C62828" FontSize="12" TextWrapping="Wrap" FontWeight="Medium"/>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource ModernButtonStyle}" IsCancel="True" Click="CancelButton_Click" Margin="0,0,10,0"/>
            <Button x:Name="OkButton" Content="Unlock" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True" Click="OkButton_Click" MinWidth="100"/>
        </StackPanel>
    </Grid>
</Window>