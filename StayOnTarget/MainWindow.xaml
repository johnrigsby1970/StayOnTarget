<Window x:Class="StayOnTarget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StayOnTarget"
        xmlns:vm="clr-namespace:StayOnTarget.ViewModels"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:StayOnTarget.Models"
        xmlns:System="clr-namespace:System;assembly=System.Runtime"
        xmlns:helpers="clr-namespace:StayOnTarget" 
        mc:Ignorable="d"
        Title="Stay On Target" Height="600" Width="1000" MinWidth="1000">
    <Window.Resources>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />

            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />

            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />

            <Setter Property="RowBackground" Value="White" />
            <Setter Property="Background" Value="White" />
            <Setter Property="GridLinesVisibility" Value="All" />
        </Style>
        <Style x:Key="ModernUnderlineTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid x:Name="Panel" Background="Transparent" Margin="0,0,14,0" SnapsToDevicePixels="True">
                            <Border x:Name="Border" Padding="2,4,2,6">
                                <ContentPresenter x:Name="ContentSite"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />
                            </Border>
                            <Border x:Name="Underline" Height="2" VerticalAlignment="Bottom" Background="Transparent" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#0284C7" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#0F172A" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="Underline" Property="Background" Value="#3b82f6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InnerTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,6,0,0" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="TextBlock.TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Background" Value="#E2E8F0" />

            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />

            <Setter Property="Padding" Value="8,6,8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />

            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />

            <Setter Property="SeparatorBrush" Value="#CBD5E1" />
        </Style>
        <Style x:Key="RightAlignedHeaderStyle"
               TargetType="{x:Type DataGridColumnHeader}"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">

            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style x:Key="CenterAlignedHeaderStyle"
               TargetType="{x:Type DataGridColumnHeader}"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">

            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <local:AmountToBrushConverter x:Key="AmountToBrushConverter" />
        <local:AbsoluteValueConverter x:Key="AbsoluteValueConverter" />
        <local:BooleanAndToVisibilityConverter x:Key="BooleanAndToVisibilityConverter" />
        <local:CategoryNameConverter x:Key="CategoryNameConverter" />
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        <local:NegativeToRedConverter x:Key="NegativeToRedConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:AccountTypeToVisibilityConverter x:Key="AccountTypeToVisibilityConverter" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <local:PaycheckFieldVisibilityConverter x:Key="PaycheckFieldVisibilityConverter" />
        <CollectionViewSource x:Key="SortedBills" Source="{Binding Bills}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Name" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <CollectionViewSource x:Key="SortedCurrentPeriodTransactions"
                              Source="{Binding CurrentPeriodTransactions}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Date" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <ObjectDataProvider x:Key="EnumFrequency"
                            MethodName="GetValues"
                            ObjectType="{x:Type models:Frequency}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:Frequency" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <!-- Style for the ToggleButton -->


        <Style x:Key="ToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Viewbox>

                            <Border x:Name="Border" CornerRadius="10"
                                    Background="#FFFFFFFF"
                                    Width="40" Height="20">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0.5" Direction="0" Opacity="0.3" />
                                </Border.Effect>
                                <Ellipse x:Name="Ellipse" Fill="#FFFFFFFF" Stretch="Uniform"
                                         Margin="2 1 2 1"
                                         Stroke="Gray" StrokeThickness="0.2"
                                         HorizontalAlignment="Stretch">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.3" Direction="260" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Viewbox>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#FF4CD661"
                                                        Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="20 1 2 1"
                                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="White"
                                                        Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="2 1 2 1"
                                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" />
                <Separator />
                <MenuItem Header="_Backup" Command="{Binding BackupCommand}" />
                <Separator />
                <MenuItem Header="_Exit" Command="{Binding ExitCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toast Notification Overlay -->
        <ItemsControl Grid.Row="1" Grid.RowSpan="2" ItemsSource="{Binding Toasts}" VerticalAlignment="Top"
                      HorizontalAlignment="Right" Margin="0,10,20,0" Panel.ZIndex="1000">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ToastViewModel}">
                    <Border Background="#FFFFA07A" BorderBrush="DarkRed" BorderThickness="1" CornerRadius="5"
                            Margin="0,0,0,10" Padding="10" Width="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5" />
                        </Border.Effect>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="X" Command="{Binding CloseCommand}"
                                    Width="20" Height="20" Margin="5,0,0,0" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" FontWeight="Bold" Foreground="DarkRed" />
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="Black" FontSize="12"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="450" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="4*" MinWidth="550" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Bills and Paychecks -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0" SelectedIndex="{Binding SelectedOuterTabIndex}">
                    <TabItem Header="Current Period">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="5" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                    <CheckBox Content="Show by Month" IsChecked="{Binding ShowByMonth}"
                                              VerticalAlignment="Center" Margin="5" />
                                    <ComboBox ItemsSource="{Binding PeriodPaychecks}" DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding SelectedPeriodPaycheckId}" Width="150" Margin="5"
                                              Visibility="{Binding ShowByMonth, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content=" &lt; " Command="{Binding PrevPeriodCommand}" Width="40"
                                            Margin="5" />
                                    <TextBlock Text="{Binding PeriodDisplay}" VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="14" Margin="10,0" />
                                    <Button Content=" &gt; " Command="{Binding NextPeriodCommand}" Width="40"
                                            Margin="5" />
                                </StackPanel>
                            </StackPanel>
                            <TabControl Style="{StaticResource InnerTabControlStyle}"
                                        ItemContainerStyle="{StaticResource ModernUnderlineTabItemStyle}"
                                        SelectedIndex="{Binding SelectedInnerTabIndex}">
                                <TabItem Header="Transaction">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,5,0,0">
                                                <Button Content="Delete"
                                                        Command="{Binding DeleteTransactionCommand}"
                                                        Width="80"
                                                        Margin="2"
                                                        Background="Red"
                                                        Foreground="White">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding EditingTransactionClone.TransactionId, Converter={StaticResource NullToVisibilityConverter}}"
                                                                    Value="Collapsed">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsEditingTransaction}"
                                                                             Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>

                                                </Button>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,5,0,0">
                                                <Button Content="Add"
                                                        Command="{Binding AddTransactionCommand}"
                                                        Visibility="{Binding IsNotEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                        Width="80"
                                                        Margin="2" />
                                                <Button Content="Edit" Command="{Binding EditTransactionCommand}"
                                                        Width="80"
                                                        Margin="2">
                                                    <Button.Visibility>
                                                        <MultiBinding
                                                            Converter="{StaticResource BooleanAndToVisibilityConverter}">
                                                            <Binding Path="CanEditTransaction" />
                                                            <Binding Path="IsNotEditingTransaction" />
                                                        </MultiBinding>
                                                    </Button.Visibility>
                                                </Button>
                                                <Button Content="Save" Command="{Binding SaveTransactionCommand}"
                                                        Width="80"
                                                        Margin="2"
                                                        Background=" CornflowerBlue"
                                                        Foreground="White"
                                                        Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Button Content="Cancel"
                                                        Command="{Binding CancelTransactionCommand}"
                                                        Width="80"
                                                        Margin="2"
                                                        Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <DataGrid Grid.Row="0"
                                                      ItemsSource="{Binding Source={StaticResource SortedCurrentPeriodTransactions}}"
                                                      SelectedItem="{Binding SelectedTransaction}"
                                                      AutoGenerateColumns="False"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True">
                                                <DataGrid.InputBindings>
                                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                                  Command="{Binding EditTransactionCommand}" />
                                                </DataGrid.InputBindings>
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Posting Date"
                                                                        HeaderStyle="{StaticResource CenterAlignedHeaderStyle}"
                                                                        Binding="{Binding TransactionDate, StringFormat='{}{0:MM/dd/yyyy}'}"
                                                                        IsReadOnly="False" Width="90">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="TextAlignment" Value="Center" />
                                                                <!-- <Setter Property="Padding" Value="0,0,8,0" />  -->

                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="Description"
                                                                        Binding="{Binding Description}" Width="Auto"
                                                                        MinWidth="100" />
                                                    <DataGridTextColumn Header="Amount"
                                                                        HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                                        Binding="{Binding Amount, StringFormat=C}"
                                                                        Width="85" MinWidth="80">
                                                        <DataGridTextColumn.ElementStyle>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="TextAlignment" Value="Right" />
                                                                <Setter Property="Padding" Value="0,0,8,0" />
                                                                <Setter Property="Foreground"
                                                                        Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" />
                                                            </Style>
                                                        </DataGridTextColumn.ElementStyle>
                                                    </DataGridTextColumn>
                                                    <DataGridTextColumn Header="From" Binding="{Binding AccountName}"
                                                                        Width="Auto" MinWidth="100" />
                                                    <DataGridTextColumn Header="To" Binding="{Binding ToAccountName}"
                                                                        Width="Auto" MinWidth="100" />
                                                    <DataGridTextColumn Header="Category"
                                                                        Binding="{Binding Converter={StaticResource CategoryNameConverter}}"
                                                                        Width="Auto"
                                                                        MinWidth="100" />
                                                    <DataGridTextColumn Header="Memo"
                                                                        Binding="{Binding Memo}" Width="Auto"
                                                                        MinWidth="100" />
                                                    
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <StackPanel Grid.Row="1" Margin="5">
                                                <TextBlock Text="Edit Transaction Item" FontWeight="Bold" Margin="0,5"
                                                           Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Grid
                                                    Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Label Grid.Column="0" Grid.Row="0" Content="Date:" />
                                                    <DatePicker Grid.Column="1" Grid.Row="0"
                                                                SelectedDate="{Binding EditingTransactionClone.TransactionDate}"
                                                                Margin="5" />

                                                    <Label Grid.Column="0" Grid.Row="1" Content="Description:" />
                                                    <ComboBox Grid.Column="1" Grid.Row="1"
                                                              ItemsSource="{Binding BillsWithNone}"
                                                              DisplayMemberPath="Name"
                                                              SelectedValuePath="Id"
                                                              SelectedValue="{Binding EditingTransactionClone.BillId, UpdateSourceTrigger=PropertyChanged}"
                                                              Text="{Binding EditingTransactionClone.Description, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEditable="True"
                                                              IsTextSearchEnabled="True"
                                                              Margin="5" />
                                                    <Label Grid.Column="2" Grid.Row="1" Content="Memo:" />
                                                    <TextBox Grid.Column="3" Grid.Row="1"
                                                             Text="{Binding EditingTransactionClone.Memo}"
                                                             Margin="5" />

                                                    <Label Grid.Column="0" Grid.Row="2" Content="Amount:" />
                                                    <TextBox Grid.Column="1" Grid.Row="2"
                                                             helpers:TextBoxBehavior.IsNumericOnly="True"
                                                             Text="{Binding EditingTransactionClone.Amount, Converter={StaticResource AbsoluteValueConverter}, StringFormat={}{0:0.00;-0.00;''}}"
                                                             Margin="5" />

                                                    <Label Grid.Column="0" Grid.Row="3" Content="From Account:" />
                                                    <ComboBox Grid.Column="1" Grid.Row="3" x:Name="FromAccountComboBox"
                                                              ItemsSource="{Binding AccountsWithNone}"
                                                              SelectedValue="{Binding EditingTransactionClone.AccountId}"
                                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                                              Margin="5" />

                                                    <Label Grid.Column="2" Grid.Row="3" Content="To Account:" />
                                                    <ComboBox Grid.Column="3" Grid.Row="3" x:Name="ToAccountComboBox"
                                                              ItemsSource="{Binding AccountsWithNone}"
                                                              SelectedValue="{Binding EditingTransactionClone.ToAccountId}"
                                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                                              Margin="5" />

                                                    <Label Grid.Column="0" Grid.Row="4" Content="Bill:" />
                                                    <ComboBox Grid.Column="1" Grid.Row="4"
                                                              x:Name="BillComboBox"
                                                              ItemsSource="{Binding BillsWithNone}"
                                                              SelectedValue="{Binding EditingTransactionClone.BillId}"
                                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                                              Margin="5" />

                                                    <Label Grid.Column="2" Grid.Row="4" Content="Bucket:" />
                                                    <ComboBox Grid.Column="3" Grid.Row="4"
                                                              x:Name="BucketComboBox"
                                                              ItemsSource="{Binding BucketsWithNone}"
                                                              SelectedValue="{Binding EditingTransactionClone.BucketId}"
                                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                                              Margin="5" />

                                                    <Label Grid.Column="0" Grid.Row="5" Content="Paycheck:">
                                                        <Label.Visibility>
                                                            <MultiBinding
                                                                Converter="{StaticResource PaycheckFieldVisibilityConverter}"
                                                                FallbackValue="Collapsed">
                                                                <Binding Path="EditingTransactionClone.ToAccountId" />
                                                                <Binding Path="Accounts" />
                                                            </MultiBinding>
                                                        </Label.Visibility>
                                                    </Label>
                                                    <ComboBox Grid.Column="1" Grid.Row="5"
                                                              ItemsSource="{Binding Paychecks}"
                                                              SelectedValue="{Binding EditingTransactionClone.PaycheckId}"
                                                              SelectedValuePath="Id" DisplayMemberPath="Name"
                                                              Margin="5">
                                                        <ComboBox.Visibility>
                                                            <MultiBinding
                                                                Converter="{StaticResource PaycheckFieldVisibilityConverter}"
                                                                FallbackValue="Collapsed">
                                                                <Binding Path="EditingTransactionClone.ToAccountId" />
                                                                <Binding Path="Accounts" />
                                                            </MultiBinding>
                                                        </ComboBox.Visibility>
                                                    </ComboBox>

                                                    <Label Grid.Column="2" Grid.Row="5" Content="Payroll Date:">
                                                        <Label.Visibility>
                                                            <MultiBinding
                                                                Converter="{StaticResource PaycheckFieldVisibilityConverter}"
                                                                FallbackValue="Collapsed">
                                                                <Binding Path="EditingTransactionClone.ToAccountId" />
                                                                <Binding Path="Accounts" />
                                                            </MultiBinding>
                                                        </Label.Visibility>
                                                    </Label>
                                                    <DatePicker Grid.Column="3" Grid.Row="5"
                                                                SelectedDate="{Binding EditingTransactionClone.PaycheckOccurrenceDate}"
                                                                Margin="5">
                                                        <DatePicker.Visibility>
                                                            <MultiBinding
                                                                Converter="{StaticResource PaycheckFieldVisibilityConverter}"
                                                                FallbackValue="Collapsed">
                                                                <Binding Path="EditingTransactionClone.ToAccountId" />
                                                                <Binding Path="Accounts" />
                                                            </MultiBinding>
                                                        </DatePicker.Visibility>
                                                    </DatePicker>

                                                    <StackPanel Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="4"
                                                                Orientation="Horizontal" Margin="5">
                                                        <CheckBox Content="Principal Only (Mortgage/Loan Extra)"
                                                                  IsChecked="{Binding EditingTransactionClone.IsPrincipalOnly}"
                                                                  VerticalAlignment="Center" Margin="0,0,10,0"
                                                                  Visibility="{Binding SelectedItem, ElementName=ToAccountComboBox, ConverterParameter='Mortgage|PersonalLoan', Converter={StaticResource AccountTypeToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                        <CheckBox Content="Rebalance (Adds to Debt)"
                                                                  IsChecked="{Binding EditingTransactionClone.IsRebalance}"
                                                                  VerticalAlignment="Center"
                                                                  Visibility="{Binding SelectedItem, ElementName=ToAccountComboBox, ConverterParameter='Mortgage|PersonalLoan', Converter={StaticResource AccountTypeToVisibilityConverter}, FallbackValue=Collapsed}" />
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </DockPanel>
                                </TabItem>
                                <TabItem Header="Bills">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Bottom">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                        HorizontalAlignment="Left"
                                                        Margin="5">
                                                <Button Content="Delete"
                                                        Command="{Binding DeletePeriodBillCommand}"
                                                        Width="80"
                                                        Margin="2"
                                                        Background="Red"
                                                        Foreground="White"
                                                        Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" Margin="5">
                                                <Button Content="Edit" Command="{Binding EditPeriodBillCommand}"
                                                        Width="80"
                                                        Margin="2">
                                                    <Button.Visibility>
                                                        <MultiBinding
                                                            Converter="{StaticResource BooleanAndToVisibilityConverter}">
                                                            <Binding Path="CanEditPeriodBill" />
                                                            <Binding Path="IsNotEditingPeriodBill" />
                                                        </MultiBinding>
                                                    </Button.Visibility>
                                                </Button>
                                                <Button Content="Save" Command="{Binding SavePeriodBillCommand}"
                                                        Width="80"
                                                        Margin="2"

                                                        Background=" CornflowerBlue"
                                                        Foreground="White"
                                                        Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                <Button Content="Cancel"
                                                        Command="{Binding CancelPeriodBillCommand}"
                                                        Width="80"
                                                        Margin="2"
                                                        Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Margin="5" TextWrapping="Wrap" Height="Auto"
                                                       Visibility="{Binding IsBillDescriptionExpanded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period.
                                                <Hyperlink Command="{Binding ToggleBillDescriptionCommand}">Read more...</Hyperlink>
                                            </TextBlock>
                                            <TextBlock Grid.Row="0" Margin="5" TextWrapping="Wrap" Height="Auto"
                                                       Visibility="{Binding IsBillDescriptionExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period and are used for projections prior to the actual bill being entered as a transaction. Once a bill is entered, the true value of the bill will show in the projection vs the anticipated amount. To set the projection for all future periods, set it in the Bills tab.
                                                <Hyperlink Command="{Binding ToggleBillDescriptionCommand}">Read less</Hyperlink>
                                            </TextBlock>
