                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTemplateColumn Header="Deposit To" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox
                                                        ItemsSource="{Binding DataContext.Accounts, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        DisplayMemberPath="Name" SelectedValuePath="Id"
                                                        SelectedValue="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="1" Margin="5"
                                            Visibility="{Binding IsEditingPaycheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Paycheck Details" FontWeight="Bold" Margin="0,5" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Label Grid.Column="0" Grid.Row="0" Content="Name:" />
                                        <TextBox Grid.Column="1" Grid.Row="0"
                                                 Text="{Binding EditingPaycheckClone.Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="5" />

                                        <Label Grid.Column="2" Grid.Row="0" Content="Amount:" />
                                        <TextBox Grid.Column="3" Grid.Row="0"
                                                 helpers:TextBoxBehavior.IsNumericOnly="True"
                                                 Text="{Binding EditingPaycheckClone.Amount, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                 Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="1" Content="Frequency:" />
                                        <ComboBox Grid.Column="1" Grid.Row="1"
                                                  ItemsSource="{Binding Source={StaticResource EnumFrequency}}"
                                                  SelectedItem="{Binding EditingPaycheckClone.Frequency}" Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="2" Content="Start date:" />
                                        <DatePicker Grid.Column="1" Grid.Row="2"
                                                    SelectedDate="{Binding EditingPaycheckClone.StartDate}" Margin="5" />

                                        <Label Grid.Column="2" Grid.Row="2" Content="End date:" />
                                        <DatePicker Grid.Column="3" Grid.Row="2"
                                                    SelectedDate="{Binding EditingPaycheckClone.EndDate}" Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="3" Content="Deposit To:" />
                                        <ComboBox Grid.Column="1" Grid.Row="3" ItemsSource="{Binding Accounts}"
                                                  SelectedValue="{Binding EditingPaycheckClone.AccountId}"
                                                  SelectedValuePath="Id" DisplayMemberPath="Name" Margin="5" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Accounts">
                        <DockPanel>
                            <Grid DockPanel.Dock="Bottom">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Delete" Command="{Binding CancelAccountCommand}"
                                            Width="80"
                                            Margin="2"
                                            Background="Red"
                                            Foreground="White">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding EditingAccountClone.Id, Converter={StaticResource IntToVisibilityConverter}}"
                                                        Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditingAccount}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Reconcile" Command="{Binding ReconcileAccountCommand}"
                                            Width="80"
                                            Margin="2"
                                            Background="YellowGreen"
                                            Foreground="White">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding EditingAccountClone.Id, Converter={StaticResource IntToVisibilityConverter}}"
                                                        Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditingAccount}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Import" Command="{Binding ImportAccountCommand}"
                                            Width="80"
                                            Margin="2"
                                            Background="YellowGreen"
                                            Foreground="White">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger
                                                        Binding="{Binding EditingAccountClone.Id, Converter={StaticResource IntToVisibilityConverter}}"
                                                        Value="Collapsed">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsEditingAccount}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Add" Command="{Binding AddAccountCommand}"
                                            Width="80"
                                            Margin="2"
                                            Visibility="{Binding IsNotEditingAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Button Content="Edit" Command="{Binding EditAccountCommand}"
                                            Width="80"
                                            Margin="2">
                                        <Button.Visibility>
                                            <MultiBinding Converter="{StaticResource BooleanAndToVisibilityConverter}">
                                                <Binding Path="CanEditAccount" />
                                                <Binding Path="IsNotEditingAccount" />
                                            </MultiBinding>
                                        </Button.Visibility>
                                    </Button>
                                    <Button Content="Save" Command="{Binding SaveAccountCommand}"
                                            Background=" CornflowerBlue"
                                            Foreground="White"
                                            Width="80"
                                            Margin="2"
                                            Visibility="{Binding IsEditingAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    <Button Content="Cancel" Command="{Binding CancelAccountCommand}"
                                            Width="80"
                                            Margin="2"
                                            Visibility="{Binding IsEditingAccount, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <DataGrid Grid.Row="0" ItemsSource="{Binding Accounts}"
                                          SelectedItem="{Binding SelectedAccount}"
                                          AutoGenerateColumns="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          CanUserAddRows="False" IsReadOnly="True">
                                    <DataGrid.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                      Command="{Binding EditAccountCommand}" />
                                    </DataGrid.InputBindings>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"
                                                            MinWidth="100" />
                                        <DataGridTextColumn Header="Balance"
                                                            Binding="{Binding Balance, StringFormat=C}"
                                                            Width="100" MinWidth="100" />
                                        <DataGridTemplateColumn Width="110" MinWidth="110" Header="Actions">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="Loan Amortization"
                                                                Command="{Binding DataContext.ShowAmortizationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Visibility="{Binding Type, ConverterParameter=Mortgage, Converter={StaticResource AccountTypeToVisibilityConverter}}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="*"
                                                            MinWidth="100" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"
                                                            MinWidth="80" />
                                        <DataGridCheckBoxColumn Header="Include in Total"
                                                                Binding="{Binding IncludeInTotal}"
                                                                Width="60" MinWidth="60">
                                            <DataGridCheckBoxColumn.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                               TextAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridCheckBoxColumn.HeaderTemplate>
                                        </DataGridCheckBoxColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="1" Margin="5"
                                            Visibility="{Binding IsEditingAccount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Account Details" FontWeight="Bold" Margin="0,5" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Label Grid.Column="0" Grid.Row="0" Content="Name:" />
                                        <TextBox Grid.Column="1" Grid.Row="0"
                                                 Text="{Binding EditingAccountClone.Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="5" />

                                        <CheckBox Grid.Column="2" Grid.Row="0" Content="Include In Total"
                                                  IsChecked="{Binding EditingAccountClone.IncludeInTotal}"
                                                  VerticalAlignment="Center" Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="1" Content="Bank:" />
                                        <TextBox Grid.Column="1" Grid.Row="1"
                                                 Text="{Binding EditingAccountClone.BankName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="5" />

                                        <Label Grid.Column="2" Grid.Row="1" Content="Type:" />
                                        <ComboBox Grid.Column="3" Grid.Row="1" ItemsSource="{Binding AccountTypes}"
                                                  SelectedItem="{Binding EditingAccountClone.Type}" Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="2" Content="Balance:" />
                                        <TextBox Grid.Column="1" Grid.Row="2"
                                                 Text="{Binding EditingAccountClone.Balance, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                 Margin="5" />

                                        <Label Grid.Column="2" Grid.Row="2" Content="As Of:" />
                                        <DatePicker Grid.Column="3" Grid.Row="2"
                                                    SelectedDate="{Binding EditingAccountClone.BalanceAsOf}" Margin="5" />

                                        <Label Grid.Column="0" Grid.Row="3" Content="Growth %:" />
                                        <TextBox Grid.Column="1" Grid.Row="3"
                                                 Text="{Binding EditingAccountClone.AnnualGrowthRate, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="5" />

                                        <Label Grid.Column="2" Grid.Row="3" Content="Color (Hex):" />
                                        <TextBox Grid.Column="3" Grid.Row="3"
                                                 Text="{Binding EditingAccountClone.HexColor, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="5" />


                                        <!-- Mortgage Specific Details -->
                                        <StackPanel Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="4"
                                                    Orientation="Vertical"
                                                    Visibility="{Binding EditingAccountClone.Type, ConverterParameter=Mortgage, Converter={StaticResource AccountTypeToVisibilityConverter}}">
                                            <TextBlock Text="Mortgage Details" FontSize="12" FontWeight="Bold"
                                                       Margin="0,5,0,5" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Label Grid.Row="0" Grid.Column="0" Content="Rate %:" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding EditingAccountClone.MortgageDetails.InterestRate, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />
                                                <Label Grid.Row="0" Grid.Column="2" Content="Escrow:" />
                                                <TextBox Grid.Row="0" Grid.Column="3"
                                                         Text="{Binding EditingAccountClone.MortgageDetails.Escrow, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />
                                                
                                                <Label Grid.Row="1" Grid.Column="0" Content="Insurance:" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding EditingAccountClone.MortgageDetails.MortgageInsurance, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />

                                                <Label Grid.Row="2" Grid.Column="0" Content="Payment:" />
                                                <TextBox Grid.Row="2" Grid.Column="1"
                                                         Text="{Binding EditingAccountClone.MortgageDetails.LoanPayment, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />
                                                <Label Grid.Row="2" Grid.Column="2" Content="Statement date:" />
                                                <DatePicker Grid.Row="2" Grid.Column="3"
                                                            SelectedDate="{Binding EditingAccountClone.MortgageDetails.PaymentDate, UpdateSourceTrigger=PropertyChanged}"
                                                            MinWidth="90"  Margin="5" />
                                            </Grid>
                                        </StackPanel>

                                        <!-- Credit Card Specific Details -->
                                        <StackPanel Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="4"
                                                    Orientation="Vertical"
                                                    Visibility="{Binding EditingAccountClone.Type, ConverterParameter=CreditCard, Converter={StaticResource AccountTypeToVisibilityConverter}}">

                                            <TextBlock Text="Credit Card Details" FontSize="12" FontWeight="Bold"
                                                       Margin="0,5,0,5" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>


                                                <Label Grid.Row="0" Grid.Column="0" Content="Statement Day:" />
                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding EditingAccountClone.CreditCardDetails.StatementDay, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />
                                                <Label Grid.Row="0" Grid.Column="2" Content="Due Date Offset:" />
                                                <TextBox Grid.Row="0" Grid.Column="3"
                                                         Text="{Binding EditingAccountClone.CreditCardDetails.DueDateOffset, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />

                                                <Label Grid.Row="1" Grid.Column="0" Content="Minimum payment:" />
                                                <TextBox Grid.Row="1" Grid.Column="1"
                                                         Text="{Binding EditingAccountClone.CreditCardDetails.MinPayFloor, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="5" />
                                                <CheckBox Grid.Row="1" Grid.Column="2" Content="Grace Period"
                                                          IsChecked="{Binding EditingAccountClone.CreditCardDetails.PayPreviousMonthBalanceInFull, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center" Margin="5"
                                                          ToolTip="Interest is not charged if previous month's balance is paid in full" />


                                                <Button Grid.Row="2" Grid.Column="0" Content="Manage Interest Rates"
                                                        Command="{Binding DataContext.SetAccountAprRatesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Margin="0,0,0,0"
                                                        Width="150"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>

                <!-- Bill Warning Widget -->
                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                        Margin="0,10,0,0" Padding="12"
                        Visibility="{Binding ShowWarningWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Bill Alerts" FontWeight="SemiBold" FontSize="14" Foreground="#0F172A"
                                   Margin="0,0,0,10" />

                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <!-- Past Due -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                                    <Path Data="M3 2v18h2V12h11l1-2-1-2H5V2H3zm4 4h7.5l.5 1-.5 1H7V6z" Fill="#EF4444" />
                                </Viewbox>
                                <StackPanel>
                                    <TextBlock Text="Past Due" FontSize="11" Foreground="#64748B" FontWeight="Medium" />
                                    <TextBlock Text="{Binding PastDueCount}" FontSize="18" FontWeight="Bold"
                                               Foreground="#0F172A" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Upcoming -->
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                                    <Path Data="M3 2v18h2V12h11l1-2-1-2H5V2H3zm4 4h7.5l.5 1-.5 1H7V6z" Fill="#EAB308" />
                                </Viewbox>
                                <StackPanel>
                                    <TextBlock Text="Upcoming" FontSize="11" Foreground="#64748B" FontWeight="Medium" />
                                    <TextBlock Text="{Binding UpcomingCount}" FontSize="18" FontWeight="Bold"
                                               Foreground="#0F172A" />
                                </StackPanel>
                            </StackPanel>
                        </UniformGrid>

                        <Separator Background="#CBD5E1" Margin="0,0,0,10" Opacity="0.5" />

                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding UnpaidPastDueBills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                                CornerRadius="6" Margin="0,0,0,6" Padding="8,6">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.MapsToBillCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <TextBlock Text="{Binding DueDate, StringFormat=MMM dd}"
                                                           DockPanel.Dock="Right" Foreground="#EF4444"
                                                           FontWeight="SemiBold" FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding BillName}" Foreground="#1E293B"
                                                           FontWeight="Medium" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Envelope Warning Widget -->
                <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                        Margin="0,10,0,0" Padding="12"
                        Visibility="{Binding ShowEnvelopeWarningWidget, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Envelope Alerts" FontWeight="SemiBold" FontSize="14" Foreground="#0F172A"
                                   Margin="0,0,0,10" />

                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <!-- Past Due -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                                    <Path Data="M3 2v18h2V12h11l1-2-1-2H5V2H3zm4 4h7.5l.5 1-.5 1H7V6z" Fill="#EF4444" />
                                </Viewbox>
                                <StackPanel>
                                    <TextBlock Text="Over Budget" FontSize="11" Foreground="#64748B"
                                               FontWeight="Medium" />
                                    <TextBlock Text="{Binding BudgetExceededCount}" FontSize="18" FontWeight="Bold"
                                               Foreground="#0F172A" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Envelope Budget Filling Up -->
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="20" Height="20" Margin="0,0,8,0">
                                    <Path Data="M3 2v18h2V12h11l1-2-1-2H5V2H3zm4 4h7.5l.5 1-.5 1H7V6z" Fill="#22C55E" />
                                </Viewbox>
                                <StackPanel>
                                    <TextBlock Text="80% Full" FontSize="11" Foreground="#64748B" FontWeight="Medium" />
                                    <TextBlock Text="{Binding EnvelopeNearingFullCount}" FontSize="18"
                                               FontWeight="Bold" Foreground="#0F172A" />
                                </StackPanel>
                            </StackPanel>
                        </UniformGrid>

                        <Separator Background="#CBD5E1" Margin="0,0,0,10" Opacity="0.5" />

                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding BudgetBustedBuckets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                                CornerRadius="6" Margin="0,0,0,6" Padding="8,6">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.MapsToBucketCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <TextBlock
                                                    Text="{Binding TransactionAmount, Converter={StaticResource AbsoluteValueConverter}, StringFormat=C}"
                                                    DockPanel.Dock="Right" FontWeight="SemiBold" FontSize="11"
                                                    VerticalAlignment="Center">

                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#22C55E" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding BudgetExceeded}"
                                                                    Value="true">
                                                                    <Setter Property="Foreground" Value="#EF4444" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>

                                                </TextBlock>

                                                <TextBlock Text="{Binding BucketName}" Foreground="#1E293B"
                                                           FontWeight="Medium" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
            <GridSplitter
                Grid.Column="1"
                Width="2"
                HorizontalAlignment="Stretch"
                Background="LightGray"
                VerticalAlignment="Stretch"
                ResizeBehavior="PreviousAndNext"
                ShowsPreview="True" />
            <!-- Right Panel: Projections -->
            <DockPanel Grid.Column="2" Margin="10,0,0,0">
                <Label DockPanel.Dock="Top" Content="Financial Projection (1 Year)" FontWeight="Bold" />
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>

                    <Border Background="#F8FAFC"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,4"
                            Margin="0,4,0,8"
                            Grid.Row="0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /> <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Label Content="Start:" VerticalAlignment="Center" Margin="5,0,0,0" />
                                <DatePicker
                                    SelectedDate="{Binding ProjectionStartDate, 
                                               Mode=TwoWay, 
                                               UpdateSourceTrigger=PropertyChanged, 
                                               TargetNullValue=''}"
                                    VerticalAlignment="Center"
                                    Margin="5,0,0,0" />

                                <Label Content="End:" VerticalAlignment="Center" Margin="12,0,0,0" />
                                <DatePicker DisplayDateStart="{x:Static System:DateTime.Today}"
                                            SelectedDate="{Binding ProjectionEndDate}"
                                            VerticalAlignment="Center"
                                            Margin="5,0,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Command="{Binding SetOneYearCommand}"
                                        Content="1 yr"
                                        Padding="10,4"
                                        Background="White"
                                        BorderBrush="#CBD5E1" />

                                <Button Command="{Binding SetFiveYearCommand}"
                                        Content="5 yr"
                                        Padding="10,4"
                                        Background="White"
                                        BorderBrush="#CBD5E1"
                                        Margin="-1,0,0,0" />

                                <Button Command="{Binding SetTenYearCommand}"
                                        Content="10 yr"
                                        Padding="10,4"
                                        Background="White"
                                        BorderBrush="#CBD5E1"
                                        Margin="-1,0,0,0" />

                                <Button Command="{Binding SetThirtyYearCommand}"
                                        Content="30 yr"
                                        Padding="10,4"
                                        Background="White"
                                        BorderBrush="#CBD5E1"
                                        Margin="-1,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="ProjectionGrid" Grid.Row="1" ItemsSource="{Binding Projections}"
                              AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="LightGray" /> <!-- Default bottom border -->
                                <Style.Triggers>
                                    <!-- Trigger for when the 'NeedsAttention' property is true -->
                                    <DataTrigger Binding="{Binding NeedsAttention}" Value="True">
                                        <Setter Property="BorderThickness" Value="0,2,0,0" />
                                        <!-- Set a thicker top border -->
                                        <Setter Property="BorderBrush" Value="black" />
                                        <!-- Color the top border red -->
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Posting Date"
                                                HeaderStyle="{StaticResource CenterAlignedHeaderStyle}"
                                                Binding="{Binding TransactionDate, StringFormat='{}{0:MM/dd/yyyy}'}"
                                                IsReadOnly="False" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <!-- <Setter Property="Padding" Value="0,0,8,0" />  -->

                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True"
                                                Width="150" />
                            <DataGridTextColumn Header="Amount"
                                                HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                Binding="{Binding Amount, StringFormat=C, UpdateSourceTrigger=PropertyChanged}"
                                                Width="90" MinWidth="80">
                                <!-- <DataGridTextColumn.ElementStyle> -->
                                <!--     <Style TargetType="TextBlock"> -->
                                <!--         <Setter Property="Foreground" Value="Black" /> -->
                                <!--         <Style.Triggers> -->
                                <!--             <DataTrigger -->
                                <!--                 Binding="{Binding Amount, Converter={StaticResource NegativeToRedConverter}}" -->
                                <!--                 Value="True"> -->
                                <!--                 <Setter Property="Foreground" Value="Red" /> -->
                                <!--             </DataTrigger> -->
                                <!--         </Style.Triggers> -->
                                <!--     </Style> -->
                                <!-- </DataGridTextColumn.ElementStyle> -->
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right" />
                                        <Setter Property="Padding" Value="0,0,8,0" />
                                        <Setter Property="Foreground"
                                                Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Total Balance"
                                                HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                Binding="{Binding Balance, StringFormat=C}"
                                                Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right" />
                                        <Setter Property="Padding" Value="0,0,8,0" />
                                        <Setter Property="Foreground"
                                                Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                <Setter Property="Foreground" Value="Red" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Period Net"
                                                HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                Binding="{Binding PeriodNet, StringFormat=C}"
                                                Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right" />
                                        <Setter Property="Padding" Value="0,0,8,0" />
                                        <Setter Property="Foreground"
                                                Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding PeriodNet, Converter={StaticResource NegativeToRedConverter}}"
                                                Value="True">
                                                <Setter Property="Foreground" Value="Red" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <GridSplitter
                        Grid.Row="2"
                        ResizeDirection="Rows"
                        Height="2"
                        HorizontalAlignment="Stretch"
                        Background="LightGray"
                        VerticalAlignment="Stretch"
                        ResizeBehavior="PreviousAndNext"
                        ShowsPreview="True" />
                    <local:ProjectionLiveChartControl Grid.Row="3"
                                                      Projections="{Binding Projections}"
                                                      Accounts="{Binding Accounts}"
                                                      Margin="0,5,0,0" />
                </Grid>
            </DockPanel>
        </Grid>
    </Grid>
</Window>