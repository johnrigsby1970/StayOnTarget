<Window x:Class="StayOnTarget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StayOnTarget"
        xmlns:vm="clr-namespace:StayOnTarget.ViewModels"
        xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:models="clr-namespace:StayOnTarget.Models"
        xmlns:System="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="Stay On Target" Height="600" Width="1000">
    <Window.Resources>
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        <local:NegativeToRedConverter x:Key="NegativeToRedConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:AccountTypeToVisibilityConverter x:Key="AccountTypeToVisibilityConverter" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <local:PaycheckFieldVisibilityConverter x:Key="PaycheckFieldVisibilityConverter" />
        <CollectionViewSource x:Key="SortedBills" Source="{Binding Bills}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Name" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <CollectionViewSource x:Key="SortedCurrentPeriodTransactions"
                              Source="{Binding CurrentPeriodTransactions}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Date" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <ObjectDataProvider x:Key="EnumFrequency"
                            MethodName="GetValues"
                            ObjectType="{x:Type models:Frequency}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:Frequency" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <!-- Style for the ToggleButton -->


        <Style x:Key="ToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Viewbox>

                            <Border x:Name="Border" CornerRadius="10"
                                    Background="#FFFFFFFF"
                                    Width="40" Height="20">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0.5" Direction="0" Opacity="0.3" />
                                </Border.Effect>
                                <Ellipse x:Name="Ellipse" Fill="#FFFFFFFF" Stretch="Uniform"
                                         Margin="2 1 2 1"
                                         Stroke="Gray" StrokeThickness="0.2"
                                         HorizontalAlignment="Stretch">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.3" Direction="260" />
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Viewbox>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Checked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#FF4CD661"
                                                        Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="20 1 2 1"
                                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Unchecked">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="White"
                                                        Duration="0:0:0.1" />
                                        <ThicknessAnimation Storyboard.TargetName="Ellipse"
                                                            Storyboard.TargetProperty="Margin"
                                                            To="2 1 2 1"
                                                            Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="2">
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding ShowAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Toast Notification Overlay -->
        <ItemsControl Grid.Row="1" Grid.RowSpan="2" ItemsSource="{Binding Toasts}" VerticalAlignment="Top"
                      HorizontalAlignment="Right" Margin="0,10,20,0" Panel.ZIndex="1000">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:ToastViewModel}">
                    <Border Background="#FFFFA07A" BorderBrush="DarkRed" BorderThickness="1" CornerRadius="5"
                            Margin="0,0,0,10" Padding="10" Width="300">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5" />
                        </Border.Effect>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="X" Command="{Binding CloseCommand}"
                                    Width="20" Height="20" Margin="5,0,0,0" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" FontWeight="Bold" Foreground="DarkRed" />
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="Black" FontSize="12"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Bills and Paychecks -->
            <TabControl Grid.Column="0">
                <TabItem Header="Current Period">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="5" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                                <CheckBox Content="Show by Month" IsChecked="{Binding ShowByMonth}"
                                          VerticalAlignment="Center" Margin="5" />
                                <ComboBox ItemsSource="{Binding PeriodPaychecks}" DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedPeriodPaycheckId}" Width="150" Margin="5"
                                          Visibility="{Binding ShowByMonth, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content=" &lt; " Command="{Binding PrevPeriodCommand}" Width="40" Margin="5" />
                                <TextBlock Text="{Binding PeriodDisplay}" VerticalAlignment="Center" FontWeight="Bold"
                                           FontSize="14" Margin="10,0" />
                                <Button Content=" &gt; " Command="{Binding NextPeriodCommand}" Width="40" Margin="5" />
                            </StackPanel>
                        </StackPanel>
                        <TabControl>
                            <TabItem Header="Bills">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                                                    Margin="5">
                                            <Button Content="Delete"
                                                    Command="{Binding DeletePeriodBillCommand}"
                                                    Width="80"
                                                    Margin="2"
                                                    Background="Red"
                                                    Foreground="White"
                                                    Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="5">
                                            <Button Content="Edit" Command="{Binding EditPeriodBillCommand}"
                                                    Visibility="{Binding CanEditPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2" />
                                            <Button Content="Cancel"
                                                    Command="{Binding CancelPeriodBillCommand}"
                                                    Width="80"
                                                    Margin="2"
                                                    Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Save" Command="{Binding SavePeriodBillCommand}"
                                                    Width="80"
                                                    Margin="2"

                                                    Background=" CornflowerBlue"
                                                    Foreground="White"
                                                    Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Margin="5" TextWrapping="Wrap" Height="Auto"
                                                       Visibility="{Binding IsBillDescriptionExpanded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period. 
                                                <Hyperlink Command="{Binding ToggleBillDescriptionCommand}">Read more...</Hyperlink>
                                            </TextBlock>
                                            <TextBlock Grid.Row="0" Margin="5" TextWrapping="Wrap" Height="Auto"
                                                       Visibility="{Binding IsBillDescriptionExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period and are used for projections prior to the actual bill being entered as a transaction. Once a bill is entered, the true value of the bill will show in the projection vs the anticipated amount. To set the projection for all future periods, set it in the Bills tab.
                                                <Hyperlink Command="{Binding ToggleBillDescriptionCommand}">Read less</Hyperlink>
                                            </TextBlock>
                                        <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentPeriodBills}"
                                                  SelectedItem="{Binding SelectedPeriodBill}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False">
                                            <DataGrid.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditPeriodBillCommand}" />
                                            </DataGrid.InputBindings>
                                            <DataGrid.Columns>
                                                <!-- <DataGridCheckBoxColumn Header="Paid" -->
                                                <!--                         Binding="{Binding IsPaid, UpdateSourceTrigger=PropertyChanged}" -->
                                                <!--                         Width="40" /> -->
                                                <DataGridTextColumn Header="Bill" Binding="{Binding BillName}"
                                                                    IsReadOnly="True" Width="*" />
                                                <DataGridTextColumn Header="Due Date"
                                                                    Binding="{Binding DueDate, StringFormat=d}"
                                                                    IsReadOnly="False" Width="80" />
                                                <DataGridTextColumn Header="Actual Amount"
                                                                    Binding="{Binding ActualAmount, StringFormat=C}"
                                                                    Width="100" />
                                                <!-- <DataGridTemplateColumn Width="80"> -->
                                                <!--     <DataGridTemplateColumn.CellTemplate> -->
                                                <!--         <DataTemplate> -->
                                                <!--             <Button Content="Remove" -->
                                                <!--                     Background="Red" -->
                                                <!--                     Foreground="White" -->
                                                <!--                     Command="{Binding DataContext.DeletePeriodBillCommand, RelativeSource={RelativeSource AncestorType=Window}}" -->
                                                <!--                     CommandParameter="{Binding}" -->
                                                <!--                     Visibility="{Binding IsPaid, Converter={StaticResource InverseBooleanToVisibilityConverter}}" /> -->
                                                <!--         </DataTemplate> -->
                                                <!--     </DataGridTemplateColumn.CellTemplate> -->
                                                <!-- </DataGridTemplateColumn> -->
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <StackPanel Grid.Row="2" Margin="10"
                                                    Visibility="{Binding IsEditingPeriodBill, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Edit Period Bill" FontWeight="Bold" Margin="0,0,0,5" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Label Grid.Column="0" Content="Name:" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditingPeriodBillClone.BillName, UpdateSourceTrigger=PropertyChanged}"
                                                         IsEnabled="False"
                                                         Margin="5" />

                                                <Label Grid.Column="2" Content="Budgeted:" />
                                                <TextBox Grid.Column="3"
                                                         Text="{Binding EditingPeriodBillClone.ActualAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                         Margin="5" />
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Envelopes">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    HorizontalAlignment="Left" Margin="5">
                                            <Button Content="Delete"
                                                    Command="{Binding DeletePeriodBucketCommand}"
                                                    Visibility="{Binding IsEditingPeriodBucket, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2"
                                                    Background="Red"
                                                    Foreground="White" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="5">
                                            <Button Content="Edit" Command="{Binding EditPeriodBucketCommand}"
                                                    Visibility="{Binding CanEditPeriodBucket, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2" />

                                            <Button Content="Cancel"
                                                    Command="{Binding CancelPeriodBucketCommand}"
                                                    Visibility="{Binding IsEditingPeriodBucket, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2" />
                                            <Button Content="Save" Command="{Binding SavePeriodBucketCommand}"
                                                    Visibility="{Binding IsEditingPeriodBucket, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2"
                                                    Background=" CornflowerBlue"
                                                    Foreground="White" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Margin="5" TextWrapping="Wrap"
                                                       Visibility="{Binding IsBucketDescriptionExpanded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period. 
                                                <Hyperlink Command="{Binding ToggleBucketDescriptionCommand}">Read more...</Hyperlink>
                                            </TextBlock>
                                            <TextBlock Margin="5" TextWrapping="Wrap"
                                                       Visibility="{Binding IsBucketDescriptionExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                Amounts set here apply only for this period. The available projected amount will adjust as transactions are entered that apply to this bucket. Once enough transactions are marked with this bucket are subtracted from the total available for the period, the projection for the remainder of the period will be zero. You can add to the envelope total for the period to give more room in this envelope. To set the projection for all future periods, set it in the Buckets tab.
                                                <Hyperlink Command="{Binding ToggleBucketDescriptionCommand}">Read less</Hyperlink>
                                            </TextBlock>
                                        </StackPanel>

                                        <DataGrid Grid.Row="1" ItemsSource="{Binding CurrentPeriodBuckets}"
                                                  SelectedItem="{Binding SelectedPeriodBucket}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False">
                                            <DataGrid.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditPeriodBucketCommand}" />
                                            </DataGrid.InputBindings>
                                            <DataGrid.Columns>
                                                <!-- <DataGridCheckBoxColumn Header="Paid" -->
                                                <!--                         Binding="{Binding IsPaid, UpdateSourceTrigger=PropertyChanged}" -->
                                                <!--                         Width="40" /> -->
                                                <DataGridTextColumn Header="Envelope" Binding="{Binding BucketName}"
                                                                    IsReadOnly="True" Width="*" />
                                                <DataGridTextColumn Header="Actual Amount"
                                                                    Binding="{Binding ActualAmount, StringFormat=C}"
                                                                    Width="100" />
                                                <!-- <DataGridTemplateColumn Width="80"> -->
                                                <!--     <DataGridTemplateColumn.CellTemplate> -->
                                                <!--         <DataTemplate> -->
                                                <!--             <Button Content="Remove" -->
                                                <!--                     Background="Red" -->
                                                <!--                     Foreground="White" -->
                                                <!--                     Command="{Binding DataContext.DeletePeriodBucketCommand, RelativeSource={RelativeSource AncestorType=Window}}" -->
                                                <!--                     CommandParameter="{Binding}" -->
                                                <!--                     Visibility="{Binding IsPaid, Converter={StaticResource InverseBooleanToVisibilityConverter}}" /> -->
                                                <!--         </DataTemplate> -->
                                                <!--     </DataGridTemplateColumn.CellTemplate> -->
                                                <!-- </DataGridTemplateColumn> -->
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="2" Margin="10"
                                                    Visibility="{Binding IsEditingPeriodBucket, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Edit Period Bucket" FontWeight="Bold" Margin="0,0,0,5" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Label Grid.Column="0" Content="Name:" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding EditingPeriodBucketClone.BucketName, UpdateSourceTrigger=PropertyChanged}"
                                                         IsEnabled="False"
                                                         Margin="5" />

                                                <Label Grid.Column="2" Content="Budgeted:" />
                                                <TextBox Grid.Column="3"
                                                         Text="{Binding EditingPeriodBucketClone.ActualAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                                         Margin="5" />
                                            </Grid>
                                            <!-- <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" -->
                                            <!--             Margin="0,5,0,0"> -->
                                            <!--     <Button Content="Save" Command="{Binding SavePeriodBucketCommand}" -->
                                            <!--             Width="80"  -->
                                            <!--             Margin="2"  -->
                                            <!--             /> -->
                                            <!--     <Button Content="Cancel" -->
                                            <!--             Command="{Binding CancelPeriodBucketCommand}"  -->
                                            <!--             Width="80" -->
                                            <!--             Margin="2"  -->
                                            <!--             /> -->
                                            <!-- </StackPanel> -->
                                        </StackPanel>
                                    </Grid>
                                </DockPanel>
                            </TabItem>
                            <TabItem Header="Transaction">
                                <DockPanel>
                                    <Grid DockPanel.Dock="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                                                    Margin="0,5,0,0">
                                            <Button Content="Delete"
                                                    Command="{Binding DeleteTransactionCommand}"
                                                    Width="80"
                                                    Margin="2"
                                                    Background="Red"
                                                    Foreground="White">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger
                                                                Binding="{Binding EditingTransactionClone.Id, Converter={StaticResource IntToVisibilityConverter}}"
                                                                Value="Collapsed">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditingTransaction}"
                                                                         Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <!-- Use MultiDataTrigger for multiple conditions -->
                                                            <!-- <MultiDataTrigger> -->
                                                            <!--     ~1~ Condition 1: Checkbox1 is checked @1@ -->
                                                            <!--     <MultiDataTrigger.Conditions> -->
                                                            <!--         <Condition Binding="{Binding IsEditingTransaction}" Value="True" /> -->
                                                            <!--         <Condition Binding="{Binding EditingTransactionClone.Id, Converter={StaticResource IntToVisibilityConverter}}" Value="Visible" /> -->
                                                            <!--     </MultiDataTrigger.Conditions> -->
                                                            <!--     ~1~ When both conditions are met, set Visibility to Visible @1@ -->
                                                            <!--     <Setter Property="Visibility" Value="Visible" /> -->
                                                            <!-- </MultiDataTrigger> -->
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>

                                            </Button>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                    HorizontalAlignment="Right"
                                                    Margin="0,5,0,0">
                                            <Button Content="Add"
                                                    Command="{Binding AddTransactionCommand}"
                                                    Visibility="{Binding IsNotEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2" />
                                            <Button Content="Edit" Command="{Binding EditTransactionCommand}"
                                                    Visibility="{Binding CanEditTransaction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                    Width="80"
                                                    Margin="2" />
                                            <Button Content="Cancel"
                                                    Command="{Binding CancelTransactionCommand}"
                                                    Width="80"
                                                    Margin="2"
                                                    Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Button Content="Save" Command="{Binding SaveTransactionCommand}"
                                                    Width="80"
                                                    Margin="2"
                                                    Background=" CornflowerBlue"
                                                    Foreground="White"
                                                    Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <DataGrid Grid.Row="0"
                                                  ItemsSource="{Binding Source={StaticResource SortedCurrentPeriodTransactions}}"
                                                  SelectedItem="{Binding SelectedTransaction}"
                                                  AutoGenerateColumns="False" 
                                                  HorizontalScrollBarVisibility="Auto"
                                                  CanUserAddRows="False" 
                                                  IsReadOnly="True">
                                            <DataGrid.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding EditTransactionCommand}" />
                                            </DataGrid.InputBindings>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Date"
                                                                    Binding="{Binding Date, StringFormat=d}" Width="80" MinWidth="80" />
                                                <DataGridTextColumn Header="Description"
                                                                    Binding="{Binding Description}" Width="Auto" MinWidth="100" />
                                                <DataGridTextColumn Header="Amount"
                                                                    Binding="{Binding Amount, StringFormat=C}"
                                                                    Width="80" MinWidth="80" />
                                                <DataGridTextColumn Header="From" Binding="{Binding AccountName}"
                                                                    Width="Auto" MinWidth="100" />
                                                <DataGridTextColumn Header="To" Binding="{Binding ToAccountName}"
                                                                    Width="Auto" MinWidth="100" />
                                                <!-- <DataGridTemplateColumn Width="80"> -->
                                                <!--     <DataGridTemplateColumn.CellTemplate> -->
                                                <!--         <DataTemplate> -->
                                                <!--             <Button Content="Remove" -->
                                                <!--                     Background="Red" -->
                                                <!--                     Foreground="White" -->
                                                <!--                     Command="{Binding DataContext.DeleteTransactionCommand, RelativeSource={RelativeSource AncestorType=Window}}" -->
                                                <!--                     CommandParameter="{Binding}" -->
                                                <!--                     Visibility="{Binding DataContext.IsNotEditingTransaction, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" /> -->
                                                <!--         </DataTemplate> -->
                                                <!--     </DataGridTemplateColumn.CellTemplate> -->
                                                <!-- </DataGridTemplateColumn> -->
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <StackPanel Grid.Row="1" Margin="5">
                                            <TextBlock Text="Edit Transaction Item" FontWeight="Bold" Margin="0,5"
                                                       Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <Grid
                                                Visibility="{Binding IsEditingTransaction, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Label Grid.Column="0" Grid.Row="0" Content="Date:" />
                                                <DatePicker Grid.Column="1" Grid.Row="0"
                                                            SelectedDate="{Binding EditingTransactionClone.Date}"
                                                            Margin="5" />

                                                <Label Grid.Column="2" Grid.Row="0" Content="Description:" />
                                                <ComboBox Grid.Column="3" Grid.Row="0"
                                                          ItemsSource="{Binding Source={StaticResource SortedBills}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding EditingTransactionClone.BillId, UpdateSourceTrigger=PropertyChanged}"
                                                          Text="{Binding EditingTransactionClone.Description, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Margin="5" />

                                                <Label Grid.Column="0" Grid.Row="1" Content="Amount:" />
                                                <TextBox Grid.Column="1" Grid.Row="1"
                                                         Text="{Binding EditingTransactionClone.Amount, StringFormat={}{0:0.00;-0.00;''}}"
                                                         Margin="5" />

                                                <Label Grid.Column="2" Grid.Row="1" Content="From Account:" />
                                                <ComboBox Grid.Column="3" Grid.Row="1" ItemsSource="{Binding Accounts}"
                                                          SelectedValue="{Binding EditingTransactionClone.AccountId}"
                                                          SelectedValuePath="Id" DisplayMemberPath="Name" Margin="5" />

                                                <Label Grid.Column="0" Grid.Row="2" Content="To Account:" />
                                                <ComboBox Grid.Column="1" Grid.Row="2" x:Name="ToAccountComboBox"
                                                          ItemsSource="{Binding Accounts}"
                                                          SelectedValue="{Binding EditingTransactionClone.ToAccountId}"
                                                          SelectedValuePath="Id" DisplayMemberPath="Name" Margin="5" />

                                                <Label Grid.Column="0" Grid.Row="3" Content="Bill:" />
                                                <ComboBox Grid.Column="1" Grid.Row="3"
