<Window x:Class="StayOnTarget.ReconciliationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:StayOnTarget"
        mc:Ignorable="d"
        Title="ReconciliationWindow" Height="450" Width="750">
    <Window.Resources>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />
        
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
        
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="Background" Value="White" />
            <Setter Property="GridLinesVisibility" Value="All" />
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#E2E8F0" />
        
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        
            <Setter Property="Padding" Value="8,6,8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        
            <Setter Property="SeparatorBrush" Value="#CBD5E1"/>
        </Style>
        <Style x:Key="RightAlignedHeaderStyle" 
               TargetType="{x:Type DataGridColumnHeader}" 
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
    
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <Style x:Key="CenterAlignedHeaderStyle" 
               TargetType="{x:Type DataGridColumnHeader}" 
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
    
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <local:AccountTypeToVisibilityConverter x:Key="AccountTypeToVisibilityConverter" />
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </Window.Resources>
    <Grid Margin="10">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" x:Name="HeaderLabel" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,5" Orientation="Horizontal">
                                        <Label Content="Beginning balance:" Margin="0,0" />
                                        <Label
                                            Content="{Binding BeginningBalance, StringFormat=C}"
                                            Width="Auto" Margin="0,0" />
                                        
                                    </StackPanel>
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ReconciliationTransactions}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False" 
                      IsReadOnly="True"
                      PreviewKeyDown="ReconciliationDataGrid_PreviewKeyDown" 
                      SelectionMode="Single"
                      >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date"
                                        HeaderStyle="{StaticResource CenterAlignedHeaderStyle}"
                                        Binding="{Binding TransactionDate, StringFormat='{}{0:MM/dd/yyyy}'}"
                                        IsReadOnly="False" Width="90"  >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Center" />
                                <!-- <Setter Property="Padding" Value="0,0,8,0" />  -->
                    
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}" Width="*" />
                    
                    <DataGridTextColumn Header="From" Binding="{Binding AccountName}"
                                        Width="100" />
                    <DataGridTextColumn Header="To" Binding="{Binding ToAccountName}"
                                        Width="100" />
                    <DataGridTextColumn Header="Amount"
                                        HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                        Binding="{Binding Amount, StringFormat=C}"
                                        Width="80" >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="Padding" Value="0,0,8,0" /> 
                            <!-- <Setter Property="Foreground"  -->
                            <!--         Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" /> -->
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Reconciled" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    IsChecked="{Binding IsReconciled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Checked="HandleCheck" Unchecked="HandleUnchecked" 
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <DataGridTextColumn Header="Balance"
                                        HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                        Binding="{Binding RunningBalance, StringFormat=C}"
                                        Width="80" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextAlignment" Value="Right" />
                                <Setter Property="Padding" Value="0,0,8,0" /> 
                                <!-- <Setter Property="Foreground"  -->
                                <!--         Value="{Binding RunningBalance, Converter={StaticResource AmountToBrushConverter}}" /> -->
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
                <StackPanel Grid.Row="2" Margin="0,5"
                            Orientation="Horizontal">
                    <Label Content="Ending balance:" Margin="0,0" />
                    <Label
                        Content="{Binding EndingBalance, StringFormat=C}"
                        Width="Auto" Margin="0,0" />
                    
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding Account.Type, ConverterParameter='RealEstate|AppreciatingAsset|Investment|Brokerage|Retirement401k|CD', Converter={StaticResource AccountTypeToVisibilityConverter}}">
                        <Label Content="Current Value:" Margin="20,0,0,0" />
                        <TextBox
                            Text="{Binding CurrentAssetValue, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                            Width="80" Margin="0,0" VerticalContentAlignment="Center" />
                        <Button Content="Adjust Balance" 
                                Command="{Binding AdjustBalanceCommand}"
                                Margin="10,0,0,0" Padding="10,0" />
                    </StackPanel>
                </StackPanel>
                <!-- <StackPanel Grid.Row="3" Margin="0,5" -->
                <!--             Orientation="Horizontal"  -->
                <!--             Visibility="{Binding Account.Type, ConverterParameter='CreditCard', Converter={StaticResource AccountTypeToVisibilityConverter}, FallbackValue=Collapsed}"> -->
                <!--      -->
                <!--     <Label Content="Reconciled balance:" Margin="0,0" /> -->
                <!--     <Label -->
                <!--         Content="{Binding NewReconciledBalance, StringFormat=C}" -->
                <!--         Width="80" Margin="0,0" /> -->
                <!--     <Label Content="Reconciled date:" Margin="0,0" /> -->
                <!--     <Label -->
                <!--         Content="{Binding NewReconciledDate, StringFormat=d}" -->
                <!--         Width="80" Margin="0,0" /> -->
                <!--                          -->
                <!-- </StackPanel> -->
                
                <!-- <StackPanel Grid.Row="3" Margin="0,5" -->
                <!--             Orientation="Horizontal"  -->
                <!--             Visibility="{Binding Account.Type, ConverterParameter='CreditCard|Checking|Savings|Mortgage|PersonalLoan', Converter={StaticResource AccountTypeToVisibilityConverter}, FallbackValue=Collapsed}"> -->
                <!--      -->
                <!--     <Label Content="Reconciled balance:" Margin="0,0" /> -->
                <!--     <Label -->
                <!--         Content="{Binding NewReconciledBalance, StringFormat=C}" -->
                <!--         Width="80" Margin="0,0" /> -->
                <!--     <Label Content="Reconciled date:" Margin="0,0" /> -->
                <!--     <Label -->
                <!--         Content="{Binding NewReconciledDate, StringFormat=d}" -->
                <!--         Width="80" Margin="0,0" /> -->
                <!--                          -->
                <!-- </StackPanel> -->
                <StackPanel Grid.Row="3" Margin="0,5"
                            Orientation="Horizontal" 
                            Visibility="{Binding Account.Type, ConverterParameter='CreditCard|Checking|Savings|Mortgage|PersonalLoan|Investment|CD|Retirement401k|Brokerage', Converter={StaticResource AccountTypeToVisibilityConverter}, FallbackValue=Collapsed}">
                    
                    <Label Content="Reconciled balance:" Margin="0,0" />

                    <TextBox
                        Text="{Binding NewReconciledBalance, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                        Width="80" Margin="0,0" />
                    <Label Content="Reconciled date:" Margin="0,0" />
                    <DatePicker Grid.Column="1" Grid.Row="0"
                                SelectedDate="{Binding NewReconciledDate, UpdateSourceTrigger=PropertyChanged}"
                                Width="80" Margin="0,0" />
                                        
                </StackPanel>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Import" Command="{Binding ImportAccountCommand}"
                            Width="75" 
                            Margin="0,0,10,0"
                            Click="HandleImportAccount_Click">
                    </Button>
                    <Button Content="OK" Width="75" Margin="0,0,10,0" 
                            Click="OkButton_Click" IsDefault="True"
                            Background="CornflowerBlue" 
                            Foreground="White"/>
                    <Button Content="Cancel" Width="75" Click="CancelButton_Click" IsCancel="True"
                            />
                </StackPanel>
                </Grid>
        </DockPanel>
    </Grid>
</Window>