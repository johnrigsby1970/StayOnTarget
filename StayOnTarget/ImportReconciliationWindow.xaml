<av:Window x:Class="StayOnTarget.Views.ImportReconciliationWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:local="clr-namespace:StayOnTarget.ViewModels"
           xmlns:av="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:stayOnTarget="clr-namespace:StayOnTarget"
           mc:Ignorable="d"
           Title="Import &amp; Reconcile QFX Transactions" Height="650" Width="900"
           WindowStartupLocation="CenterScreen">

    <av:Window.Resources>
        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />
        
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
        
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="Background" Value="White" />
            <Setter Property="GridLinesVisibility" Value="All" />
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3B82F6" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3B82F6" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
            </Style.Resources>
        </Style>
        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#E2E8F0" />
        
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        
            <Setter Property="Padding" Value="8,6,8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        
            <Setter Property="SeparatorBrush" Value="#CBD5E1"/>
        </Style>
        <Style x:Key="RightAlignedHeaderStyle" 
               TargetType="{x:Type DataGridColumnHeader}" 
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
    
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>
        <stayOnTarget:AccountTypeToVisibilityConverter x:Key="AccountTypeToVisibilityConverter" />
        <stayOnTarget:AbsoluteValueConverter x:Key="AbsoluteValueConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <stayOnTarget:PaycheckFieldVisibilityConverter x:Key="PaycheckFieldVisibilityConverter" />
        <DataTemplate DataType="{x:Type local:NewTransactionViewModel}">
            <stayOnTarget:NewTransactionOverlayView />
        </DataTemplate>
    </av:Window.Resources>

    <!-- <av:Window.DataContext> -->
    <!--     <local:ImportReconciliationViewModel /> -->
    <!-- </av:Window.DataContext> -->
    <Grid Margin="10">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" x:Name="HeaderLabel" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
            <av:Grid Margin="15">
                <av:Grid.RowDefinitions>
                    <av:RowDefinition Height="Auto" />
                    <av:RowDefinition Height="*" MinHeight="200" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" MinHeight="100" />
                    <RowDefinition Height="Auto" />
                </av:Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Reconcile Import" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />

                <GroupBox Grid.Row="1" Header="1. Imported Bank Transactions">
                    <DataGrid ItemsSource="{Binding ImportedTransactions}"
                              SelectedItem="{Binding SelectedImported}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              RowDetailsVisibilityMode="Collapsed">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox Command="{Binding DataContext.ToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                    </DataTemplate>
                                </DataGridCheckBoxColumn.HeaderTemplate>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="80" IsReadOnly="True" />
                            <DataGridTextColumn Header="Payee (Import)" Binding="{Binding Payee}" Width="*" IsReadOnly="True" />
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="80" IsReadOnly="True" />
                            <DataGridComboBoxColumn Header="Bill" 
                                                    SelectedValueBinding="{Binding BillId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="Name"
                                                    Width="120">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource" Value="{Binding DataContext.BillsWithNone, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReconciled}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource" Value="{Binding DataContext.BillsWithNone, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReconciled}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridComboBoxColumn Header="Bucket" 
                                                    SelectedValueBinding="{Binding BucketId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="Name"
                                                    Width="120">
                                <DataGridComboBoxColumn.ElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource" Value="{Binding DataContext.BucketsWithNone, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReconciled}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridComboBoxColumn.ElementStyle>
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="ItemsSource" Value="{Binding DataContext.BucketsWithNone, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReconciled}" Value="True">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Reconciliation Status" Binding="{Binding Status}" Width="150" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              Background="#DDD" Margin="0,5" />

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="2. Unreconciled Manual Entries (Match Candidates)">
                        <DataGrid ItemsSource="{Binding UnreconciledManualTransactions}"
                                  SelectedItem="{Binding SelectedManual}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMatched}" Value="True">
                                            <Setter Property="Background" Value="DodgerBlue"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding TransactionDate, StringFormat=d}" Width="100" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <Button Content="Link Selections"
                                Command="{Binding LinkTransactionsCommand}"
                                Padding="10,8" Margin="0,0,0,10" />

                        <Button Content="Import Selected Transaction"
                                Command="{Binding ImportAsNewCommand}"
                                Padding="10,8" Margin="0,0,0,15" />
                        
                        <Button Content="Clear Match"
                                Command="{Binding  ClearMatchCommand}"
                                Padding="10,8" Margin="0,0,0,15" />

                        <TextBlock
                            Text="💡 Tip: Select a bank transaction above, then pair it with your manual entry below and click Link."
                            TextWrapping="Wrap" FontSize="11" Foreground="#666" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Open Transaction File..."
                            Command="{Binding ImportFileCommand}"
                            Padding="10,4"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right" />
                    
                    <!-- <Button Content="Open QFX File..." -->
                    <!--         Command="{Binding ImportQfxCommand}" -->
                    <!--         Padding="10,4" -->
                    <!--         Margin="0,0,10,0" -->
                    <!--         HorizontalAlignment="Right" /> -->
                    <!-- -->
                    <!-- <Button Content="Open CSV File..." -->
                    <!--         Command="{Binding ImportCsvCommand}" -->
                    <!--         Padding="10,4" -->
                    <!--         Margin="0,0,10,0" -->
                    <!--         HorizontalAlignment="Right" /> -->

                    <Button Content="Update Transactions" 
                            Command="{Binding SaveCommand}"
                            Width="120" Padding="5" IsDefault="True" 
                            Margin="0,0,10,0" />
                    <Button Content="Close" Width="80" Padding="5" IsCancel="True" />
                </StackPanel>
            </av:Grid>
        </DockPanel>

        <!-- CSV Mapping Overlay -->
        <Grid Background="#80000000" Visibility="{Binding IsMappingVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="White" Width="600" VerticalAlignment="Center" Padding="20" CornerRadius="8" BorderBrush="Gray" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Map CSV Columns" FontSize="16" FontWeight="Bold" Margin="0,0,0,15" />
        
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Date Column:" VerticalAlignment="Center" Margin="0,5" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding CsvMapping.AvailableHeaders}" SelectedItem="{Binding CsvMapping.DateHeader}" Margin="0,5" />
        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Amount Column:" VerticalAlignment="Center" Margin="0,5" />
                        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding CsvMapping.AvailableHeaders}" SelectedItem="{Binding CsvMapping.AmountHeader}" Margin="0,5" />
        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Payee Column:" VerticalAlignment="Center" Margin="0,5" />
                        <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding CsvMapping.AvailableHeaders}" SelectedItem="{Binding CsvMapping.PayeeHeader}" Margin="0,5" />
        
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="FITID / Reference:" VerticalAlignment="Center" Margin="0,5" />
                        <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding CsvMapping.AvailableHeaders}" SelectedItem="{Binding CsvMapping.BankIdHeader}" Margin="0,5" />
                    </Grid>
        
                    <TextBlock Text="Preview (First 5 Rows):" FontWeight="Bold" Margin="0,10,0,5" />
                    <DataGrid ItemsSource="{Binding CsvMapping.PreviewRows}" Height="150" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='{}{0:MM/dd/yyyy}'}"
                                                IsReadOnly="False" Width="90"  >
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center" />
                                        <!-- <Setter Property="Padding" Value="0,0,8,0" />  -->
                    
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Payee" Binding="{Binding Payee}" Width="*" />
                            <DataGridTextColumn Header="Amount" HeaderStyle="{StaticResource RightAlignedHeaderStyle}"
                                                
                                                Binding="{Binding Amount, StringFormat=C}" Width="100" >
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right" />
                                        <Setter Property="Padding" Value="0,0,8,0" /> 
                                        <!-- <Setter Property="Foreground"  -->
                                        <!--         Value="{Binding Amount, Converter={StaticResource AmountToBrushConverter}}" /> -->
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="BankId" Binding="{Binding BankId}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
        
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Command="{Binding CancelCsvImportCommand}" Width="80" Margin="0,0,10,0" />
                        <Button Content="Load" Command="{Binding ConfirmCsvImportCommand}" Width="100" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        
        <ContentControl Content="{Binding ActiveOverlay}" />
    </Grid>
</av:Window>